  "readme_html": "\n        \n          <p><img src=\"https://ollama.com/assets/library/qwen2-math/c0159f63-bf4d-4b0d-9b92-ea44c48d34c1\" width=\"380\"/></p>\n\n<p><strong>Qwen2 Math</strong> features 3 model sizes (<strong>1.5B</strong>, <strong>7B</strong>, and <strong>72B</strong>) each with a <strong>base</strong> model, for completion, few-shot inference, and fine-tuning, and an <strong>instruct</strong> model for chatting.</p>\n\n<h2>References:</h2>\n\n<ul>\n<li><a href=\"https://qwenlm.github.io/blog/qwen2-math/\" rel=\"nofollow\">Qwen 2 Math Blog Post</a></li>\n<li><a href=\"https://github.com/QwenLM/Qwen2-Math\" rel=\"nofollow\">GitHub Repository</a></li>\n<li><a href=\"https://huggingface.co/collections/Qwen/qwen2-math-66b4c9e072eda65b5ec7534d\" rel=\"nofollow\">Hugging Face</a></li>\n</ul>\n\n        \n      ",
